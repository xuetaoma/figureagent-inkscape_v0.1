INKSCAPE_COPILOT_PROVIDER=openai
MAIN_MODEL=gpt-5.4
OPENAI_MODEL=gpt-5.4
OPENAI_API_KEY=your_openai_key_here
INKSCAPE_COPILOT_IMAGE_DETAIL=low
INKSCAPE_COPILOT_API_TIMEOUT_SECONDS=180

